---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-headline">
      Hiring? <a href="mailto:hello@5am.dev">Let's&nbsp;talk.</a>
    </div>
    <div class="footer-end">
      <div>© {currentYear} · Sam Ayres</div>
      <div class="right">
        <a href="mailto:hello@5am.dev">Email</a>
        <a href="https://github.com/samayres1992" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com/in/samayres1992" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 3rem 0 2.25rem;
    background: var(--bg-deep);
  }

  .footer-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: -0.01em;
    text-align: center;
    padding: 0.15em 0.5rem;
    margin: 0 auto 2.5rem;
  }

  .footer-headline a {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 0.125rem solid var(--teal);
    padding-bottom: 0.1em;
    transition: opacity 0.2s;
  }

  .footer-headline a:hover {
    opacity: 0.8;
  }

  .footer-end {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
  }

  .footer-end a {
    color: var(--ink);
    text-decoration: none;
  }

  .footer-end a:hover {
    color: var(--teal);
  }

  .footer-end .right {
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    footer {
      padding: 2.5rem 0 2rem;
    }
    .footer-headline {
      margin-bottom: 2rem;
    }
    .footer-end {
      gap: 1rem;
      font-size: 0.6875rem;
    }
    .footer-end .right {
      gap: 0.875rem;
    }
  }
</style>
