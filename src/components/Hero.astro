---
// Hero — eyebrow location, name as h1, statement as h2, contact row
---

<section class="hero">
  <div class="hero-eyebrow">
    <span class="dot" aria-hidden="true"></span>
    Director of Technology · Brooklyn, NY
  </div>
  <h1 class="hero-name">Sam Ayres</h1>
  <h2 class="hero-statement">
    A decade of building.<br />
    Now building teams that build.
  </h2>
  <div class="hero-meta">
    <a href="mailto:hello@5am.dev">Email</a>
    <a href="https://github.com/samayres1992" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://linkedin.com/in/samayres1992" target="_blank" rel="noopener noreferrer">LinkedIn</a>
  </div>
</section>

<style>
  .hero {
    padding: var(--section-pad) 0;
    position: relative;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }

  .hero-eyebrow .dot {
    width: 0.375rem;
    height: 0.375rem;
    background: var(--teal);
    border-radius: 50%;
    box-shadow: 0 0 0.5rem var(--teal);
    flex-shrink: 0;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 11vw, 11.25rem);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    word-break: break-word;
  }

  .hero-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3.25rem);
    line-height: 1.1;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink-soft);
    margin-bottom: 1.75rem;
    max-width: 56.25rem;
  }

  .hero-summary {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 40rem;
    margin-bottom: 2.75rem;
  }

  .hero-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .hero-meta a {
    color: var(--ink);
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 6.25rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
  }

  .hero-meta a:hover {
    border-color: var(--teal);
    color: var(--teal);
    background: var(--bg);
  }

  .hero-meta a::before {
    content: '→';
    color: var(--teal);
  }

  @media (max-width: 600px) {
    .hero-eyebrow {
      margin-bottom: 1.5rem;
    }
    .hero-name {
      font-size: clamp(3rem, 14vw, 6rem);
    }
    .hero-summary {
      font-size: 0.9375rem;
      margin-bottom: 2.25rem;
    }
    .hero-meta {
      gap: 0.5rem;
      font-size: 0.6875rem;
    }
    .hero-meta a {
      padding: 0.625rem 0.875rem;
    }
  }
</style>
