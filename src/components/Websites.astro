---
import SectionHead from './SectionHead.astro';
---

<section id="websites">
  <SectionHead title="Selected Work" />

  <div class="featured-list">
    {/* locc.it */}
    <article class="featured">
      <div class="featured-body">
        <div class="featured-eyebrow">
          <span class="dot" aria-hidden="true"></span>
          Personal · Open source
        </div>

        <a href="/work/locc-it" class="featured-title-link">
          <h3 class="featured-title">locc.it</h3>
        </a>

        <p class="featured-desc">
          A one-time secret sharing tool. The sender encrypts in the browser
          with a generated passcode, the server stores only the ciphertext on
          a deadline, and the recipient opens the link exactly once before it
          is deleted.
        </p>

        <div class="featured-stack">
          <span>Stack:</span> React · Express · SQLite · CryptoJS
        </div>
      </div>

      <aside class="featured-meta">
        <svg class="featured-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <rect x="9" y="22" width="30" height="20" rx="2" stroke="currentColor" stroke-width="2" />
          <path d="M16 22v-7a8 8 0 0 1 16 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <circle cx="24" cy="32" r="2" fill="currentColor" />
        </svg>

        <dl class="featured-facts">
          <div class="featured-fact">
            <dt>Live since</dt>
            <dd><span>2019</span></dd>
          </div>
          <div class="featured-fact">
            <dt>Live site</dt>
            <dd>
              <a href="https://locc.it" target="_blank" rel="noopener noreferrer">
                locc.it <span aria-hidden="true">↗</span>
              </a>
            </dd>
          </div>
          <div class="featured-fact">
            <dt>Source</dt>
            <dd>
              <a href="https://github.com/samayres1992/locc.it" target="_blank" rel="noopener noreferrer">
                GitHub <span aria-hidden="true">↗</span>
              </a>
            </dd>
          </div>
        </dl>

        <a href="/work/locc-it" class="featured-cta">
          Read the case study <span aria-hidden="true">→</span>
        </a>
      </aside>
    </article>

    {/* Drupal → Bitbucket Automation */}
    <article class="featured">
      <div class="featured-body">
        <div class="featured-eyebrow">
          <span class="dot" aria-hidden="true"></span>
          Personal · Open source
        </div>

        <a href="/work/drupal-bitbucket" class="featured-title-link">
          <h3 class="featured-title">Drupal → Bitbucket Automation</h3>
        </a>

        <p class="featured-desc">
          A Drupal 7 module that hooks into the project-create event and
          automatically provisions a private Bitbucket repository with the
          agency workflow already enforced: branch protection, approval rules,
          push restrictions, and PR webhooks.
        </p>

        <div class="featured-stack">
          <span>Stack:</span> PHP · Drupal 7 · Bitbucket REST API · OAuth2
        </div>
      </div>

      <aside class="featured-meta">
        <svg class="featured-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <line x1="14" y1="10" x2="14" y2="38" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M14 24 L30 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <circle cx="14" cy="14" r="3" stroke="currentColor" stroke-width="2" fill="none" />
          <circle cx="14" cy="34" r="3" stroke="currentColor" stroke-width="2" fill="none" />
          <circle cx="34" cy="24" r="3" stroke="currentColor" stroke-width="2" fill="none" />
        </svg>

        <dl class="featured-facts">
          <div class="featured-fact">
            <dt>Built in</dt>
            <dd><span>2018</span></dd>
          </div>
          <div class="featured-fact">
            <dt>Type</dt>
            <dd><span>Drupal 7 module</span></dd>
          </div>
          <div class="featured-fact">
            <dt>Source</dt>
            <dd>
              <a href="https://github.com/samayres1992/Drupal-Bitbucket-integration" target="_blank" rel="noopener noreferrer">
                GitHub <span aria-hidden="true">↗</span>
              </a>
            </dd>
          </div>
        </dl>

        <a href="/work/drupal-bitbucket" class="featured-cta">
          Read the case study <span aria-hidden="true">→</span>
        </a>
      </aside>
    </article>
  </div>
</section>

<style>
  section {
    padding: var(--section-pad) 0;
    border-top: 1px solid var(--line);
  }

  /* Container that stacks featured cards vertically with consistent gap */
  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Featured project card — wider two-column callout used in this section.
     Body left (title + description + stack), aside right (icon, facts, CTA),
     separated by a vertical line. */
  .featured {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 0.25rem;
    padding: 2.5rem 2.75rem;
    transition: border-color 0.3s ease;
  }

  .featured:hover {
    border-color: var(--teal);
  }

  /* ----- Body (left) ----- */
  .featured-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .featured-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .featured-eyebrow .dot {
    width: 0.375rem;
    height: 0.375rem;
    background: var(--teal);
    border-radius: 50%;
    box-shadow: 0 0 0.5rem var(--teal);
    flex-shrink: 0;
  }

  .featured-title-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .featured-title-link:hover {
    color: var(--teal);
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .featured-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    max-width: 38rem;
  }

  .featured-stack {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink);
    letter-spacing: 0.03em;
    padding-top: 0.75rem;
    margin-top: auto;
  }

  .featured-stack span {
    color: var(--ink-soft);
  }

  /* ----- Meta (right aside) ----- */
  .featured-meta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-left: 1px solid var(--line);
    padding-left: 2.5rem;
  }

  .featured-mark {
    width: 3rem;
    height: 3rem;
    color: var(--teal);
  }

  .featured-facts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
  }

  .featured-fact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .featured-fact dt {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0;
  }

  .featured-fact dd {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--ink);
    line-height: 1.4;
  }

  .featured-fact dd a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }

  .featured-fact dd a:hover {
    color: var(--teal);
  }

  .featured-fact dd a span {
    color: var(--teal);
    margin-left: 0.25rem;
  }

  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--teal);
    text-decoration: none;
    padding-top: 0.5rem;
    margin-top: auto;
    transition: color 0.2s;
  }

  .featured-cta:hover {
    color: var(--ink);
  }

  /* Stack on small screens so the meta sits below the body */
  @media (max-width: 720px) {
    .featured {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.75rem;
    }

    .featured-meta {
      border-left: none;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: 2rem;
    }
  }
</style>
