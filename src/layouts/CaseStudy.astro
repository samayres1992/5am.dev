---
import Base from './Base.astro';

export interface Props {
  title: string;
  tag: string;
  role: string;
  timeframe?: string;
  stack?: string;
  oneliner: string;
  links?: { label: string; url: string }[];
  parentHref?: string;
  parentLabel?: string;
  noindex?: boolean;
}

const {
  title,
  tag,
  role,
  timeframe,
  stack,
  oneliner,
  links,
  parentHref = '/#work',
  parentLabel = 'work',
  noindex = false,
} = Astro.props;
---

<Base title={`${title}, Sam Ayres`} description={oneliner} noindex={noindex}>
  <div class="beam" aria-hidden="true">
    <div class="beam-line"></div>
    <div class="beam-glow"></div>
  </div>
  <div class="top-fade" aria-hidden="true"></div>

  <main>
    <div class="container">
      <a href={parentHref} class="back-link">
        <span aria-hidden="true">←</span> Back to {parentLabel}
      </a>

      <header class="cs-hero">
        <div class="cs-tag">{tag}</div>
        <h1 class="cs-title">{title}</h1>
        <p class="cs-oneliner">{oneliner}</p>

        {links && links.length > 0 && (
          <div class="cs-links">
            {links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.label} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )}

        <dl class="cs-meta">
          <div>
            <dt>Role</dt>
            <dd>{role}</dd>
          </div>
          {timeframe && (
            <div>
              <dt>Timeframe</dt>
              <dd>{timeframe}</dd>
            </div>
          )}
          {stack && (
            <div>
              <dt>Stack</dt>
              <dd>{stack}</dd>
            </div>
          )}
        </dl>
      </header>

      <article class="cs-body">
        <slot />
      </article>

      <nav class="cs-next">
        <a href={parentHref}>
          <span class="cs-next-label">Next</span>
          <span class="cs-next-title">See all {parentLabel} →</span>
        </a>
      </nav>
    </div>
  </main>
</Base>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 4rem 0 0;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--teal);
  }

  .cs-hero {
    padding: 3rem 0 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 5rem;
  }

  .cs-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .cs-tag::before {
    content: '';
    width: 0.375rem;
    height: 0.375rem;
    background: var(--teal);
    border-radius: 50%;
    box-shadow: 0 0 0.5rem var(--teal);
  }

  .cs-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8.75rem);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    word-break: break-word;
  }

  .cs-oneliner {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 3vw, 2.25rem);
    line-height: 1.3;
    color: var(--ink-soft);
    max-width: 50rem;
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .cs-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .cs-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 6.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink);
    text-decoration: none;
    transition: all 0.2s;
    line-height: 1;
  }

  .cs-links a:hover {
    border-color: var(--teal);
    color: var(--teal);
    background: var(--bg);
  }

  .cs-links a span {
    color: var(--teal);
  }

  .cs-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
    align-items: center;
  }

  .cs-meta div {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }

  .cs-meta dt {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    flex-shrink: 0;
  }

  .cs-meta dd {
    font-size: 0.875rem;
    color: var(--ink);
    line-height: 1.5;
  }

  .cs-body {
    padding-bottom: 7.5rem;
  }

  /* Constrain prose for readability but let full-width elements (diagrams, outcome grids) breathe */
  .cs-body :global(p),
  .cs-body :global(ul),
  .cs-body :global(.lede),
  .cs-body :global(h2),
  .cs-body :global(h3) {
    max-width: 51.25rem;
  }

  /* Defaults for content within slot */
  .cs-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 5rem 0 1.5rem;
  }

  .cs-body :global(h2:first-child) {
    margin-top: 0;
  }

  .cs-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 400;
    margin: 3rem 0 1rem;
    color: var(--ink);
  }

  .cs-body :global(p) {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: 1.25rem;
  }

  .cs-body :global(p strong) {
    color: var(--ink);
    font-weight: 500;
  }

  .cs-body :global(.lede) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: 2rem;
    font-weight: 400;
  }

  .cs-body :global(ul) {
    list-style: none;
    margin-bottom: 2rem;
  }

  .cs-body :global(ul li) {
    font-size: 1.0625rem;
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.75rem;
  }

  .cs-body :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-weight: 500;
  }

  .cs-body :global(.outcome-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11.25rem, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin: 2rem 0 3rem;
  }

  .cs-body :global(.outcome-grid > div) {
    background: var(--bg);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cs-body :global(.outcome-grid strong) {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1;
    color: var(--teal);
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .cs-body :global(.outcome-grid span) {
    font-size: 0.8125rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* Next nav */
  .cs-next {
    border-top: 1px solid var(--line);
    padding: 4rem 0;
  }

  .cs-next a {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: opacity 0.2s;
  }

  .cs-next a:hover {
    opacity: 0.8;
  }

  .cs-next-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .cs-next-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    color: var(--ink);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  @media (max-width: 700px) {
    .back-link {
      padding-top: 2.5rem;
    }
    .cs-hero {
      padding: 2rem 0 3.75rem;
      margin-bottom: 3.75rem;
    }
    .cs-meta {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .cs-body {
      padding-bottom: 5rem;
    }
    .cs-body :global(h2) {
      margin: 3.75rem 0 1.25rem;
    }
  }
</style>
